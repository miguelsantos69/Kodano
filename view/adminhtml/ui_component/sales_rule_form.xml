<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="rule_information">
        <field name="coupon_type">
            <settings>
                <switcherConfig>
                    <rules>
                        <rule name="0">
                            <value>1</value>
                            <actions>
                                <action name="3">
                                    <target>sales_rule_form.sales_rule_form.rule_information.on_mobile</target>
                                    <callback>hide</callback>
                                </action>
                            </actions>
                        </rule>
                        <rule name="1">
                            <value>2</value>
                            <actions>
                                <action name="3">
                                    <target>sales_rule_form.sales_rule_form.rule_information.on_mobile</target>
                                    <callback>show</callback>
                                </action>
                            </actions>
                        </rule>
                        <rule name="2">
                            <value>3</value>
                            <actions>
                                <action name="3">
                                    <target>sales_rule_form.sales_rule_form.rule_information.on_mobile</target>
                                    <callback>hide</callback>
                                </action>
                            </actions>
                        </rule>
                    </rules>
                </switcherConfig>
            </settings>
        </field>
        <field name="on_mobile" formElement="checkbox" sortOrder="80">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Coupon Is Mobile</label>
                <dataScope>on_mobile</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
</form>
