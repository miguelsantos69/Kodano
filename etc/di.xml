<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\SalesRule\Model\Utility">
        <plugin name="prevent_sales_rule_mobile"
                type="Kodano\MobileCoupon\Plugin\PreventMobileOnlyCouponUsage"
                sortOrder="100"/>
    </type>

    <preference for="Kodano\MobileCoupon\Api\Service\DeviceContextValidatorInterface"
                type="Kodano\MobileCoupon\Service\DeviceContextValidator"/>
    <preference for="Kodano\MobileCoupon\Api\Service\MobileCouponServiceInterface"
                type="Kodano\MobileCoupon\Service\MobileCouponService"/>
</config>

